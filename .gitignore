# =====================================================================
# RL-Drive .gitignore
# Principle: track code + docs only. All runtime artifacts live outside
# git (workspace-mounted), not committed.
# =====================================================================

# ---------- data / models / checkpoints (NEVER commit) ----------
data/**
!data/.gitkeep
!data/README.md

models/
ckpt/
checkpoints/
pretrained/
*.pkl
*.pth
*.pt
*.bin
*.safetensors
*.ckpt
*.npy
*.npz

# ---------- experiment / log / result outputs ----------
exp/**
!exp/.gitkeep
!exp/README.md

logs/**
!logs/.gitkeep
!logs/README.md

results/**
!results/.gitkeep
!results/README.md

wandb/
mlruns/
tb_logs/
tensorboard/
outputs/
*.log
*.out
*.err
core.*
slurm-*.out

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg
pip-wheel-metadata/

# virtual envs (envs/ lives in workspace root, not repo, but be safe)
.venv/
venv/
env/
ENV/

# testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml

# type checking
.mypy_cache/
.pyre/
.dmypy.json
.ruff_cache/

# ---------- Jupyter ----------
.ipynb_checkpoints/
*.ipynb_metadata
profile_default/
ipython_config.py

# ---------- IDE / editor ----------
.vscode/
.idea/
.cursor/
.codebuddy/
*.swp
*.swo
*~
.project
.pydevproject

# ---------- OS junk ----------
.DS_Store
Thumbs.db
Desktop.ini

# ---------- secrets ----------
.env
.env.*
!.env.example
*.secret
secrets/
credentials.json
api_key*
*.pem

# ---------- HuggingFace cache (in case user mis-points) ----------
.cache/
huggingface/
transformers_cache/

# deprecated early-draft milestones (kept on disk for history, not pushed)
docs/plan/milestones.md

# internal handoff doc, never push
docs/_internal/

# ---------- third-party / vendored repos ----------
# AutoVLA upstream clone (ucla-mobility/AutoVLA). Local edits are tracked
# via patch files under docs/_internal/patches/ (gitignored too).
# DO NOT add this directory to git — it contains a separate repo + 16GB ckpt.
code/third_party/

# ---------- launch scripts (contain absolute /apdcephfs paths, not for public push) ----------
# Internal copies live in docs/_internal/scripts_internal/
scripts/

# ---------- local artifacts (do not commit) ----------
backups/
results/raw/
results/profiling/
STOP_*
landscape_queue.txt
*.zip
